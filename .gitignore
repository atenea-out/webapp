# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# local database
*.db
*.db-*

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# payload uploads are stored on a persistent volume in production
/public/media/*
!/public/media/.gitkeep
!/public/media/hero-atenea.mp4
!/public/media/hero-atenea-poster.jpg
!/public/media/images/
!/public/media/images/*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
